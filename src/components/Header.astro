---
import HeaderLink from './HeaderLink.astro';
import config from '../content/config/config.json';
import IconLink from './react/IconLink';
import { withBase } from '../utils/withBase';
---

<header class="site-shell site-header-wrap">
  <nav class="site-panel site-header" aria-label="Primary">
    <a class="brand-mark" href={withBase('/')}>
      <span class="brand-chip">DA</span>
      <span>
        <strong>{config.seo.title}</strong>
        <small>Code / Music / Notes</small>
      </span>
    </a>
    <div class="nav-links">
      {config.nav.map((nav) => <HeaderLink href={nav.link}>{nav.title}</HeaderLink>)}
    </div>
    {config.contactLinks?.length > 0 && (
      <div class="social-links">
        {config.contactLinks.map(({ title, icon, link }) => (
          <IconLink title={title} icon={icon} link={link.startsWith('/') ? withBase(link) : link} />
        ))}
      </div>
    )}
  </nav>
</header>

<style>
  .site-header-wrap {
    padding-top: 1rem;
  }

  .site-header {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
  }

  .brand-mark {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    text-decoration: none;
  }

  .brand-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border: 3px solid var(--border);
    background: var(--brand-4);
    box-shadow: 4px 4px 0 rgba(31, 34, 48, 0.12);
    font-family: 'Silkscreen', sans-serif;
    font-size: 0.9rem;
  }

  .brand-mark strong,
  .brand-mark small {
    display: block;
  }

  .brand-mark strong {
    font-family: 'Silkscreen', sans-serif;
    font-size: 0.95rem;
    text-transform: uppercase;
  }

  .brand-mark small {
    margin-top: 0.2rem;
    color: var(--muted);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .nav-links,
  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
  }

  .nav-links {
    justify-content: center;
  }

  .social-links :global(a) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 2px solid var(--border);
    background: #fff;
    box-shadow: 4px 4px 0 rgba(31, 34, 48, 0.08);
  }

  .social-links :global(a:hover) {
    transform: translate(-1px, -1px);
  }

  @media (max-width: 900px) {
    .site-header {
      grid-template-columns: 1fr;
    }

    .nav-links {
      justify-content: flex-start;
    }
  }

  @media (max-width: 640px) {
    .brand-mark {
      align-items: flex-start;
    }
  }
</style>
