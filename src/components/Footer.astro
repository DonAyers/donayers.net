---
import config from '../content/config/config.json';
import IconLink from './react/IconLink';
import { withBase } from '../utils/withBase';
const today = new Date();
---

<footer class="site-shell footer-wrap">
  <div class="site-panel footer-panel">
    <div>
      <p class="footer-kicker">Built for the web, tuned for the tiny details.</p>
      <p class="footer-copy">&copy; {today.getFullYear()} {config.seo.siteOwner}. Static Astro site with a lightweight pixel-art finish.</p>
    </div>
    {config.contactLinks?.length > 0 && (
      <div class="social-links">
        {config.contactLinks.map(({ title, icon, link }) => (
          <IconLink title={title} icon={icon} link={link.startsWith('/') ? withBase(link) : link} />
        ))}
      </div>
    )}
  </div>
</footer>

<style>
  .footer-wrap {
    padding-bottom: 2rem;
  }

  .footer-panel {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .footer-kicker {
    margin-bottom: 0.35rem;
    font-family: 'Silkscreen', sans-serif;
    font-size: 0.8rem;
    text-transform: uppercase;
  }

  .footer-copy {
    color: var(--muted);
    font-size: 0.85rem;
  }

  .social-links {
    display: flex;
    gap: 0.65rem;
    flex-wrap: wrap;
  }

  .social-links :global(a) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 2px solid var(--border);
    background: #fff;
    box-shadow: 4px 4px 0 rgba(31, 34, 48, 0.08);
  }

  @media (max-width: 720px) {
    .footer-panel {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
