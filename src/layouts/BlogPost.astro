---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Header />
    <main class="site-shell page-stack">
      <section class="site-panel" style="display:grid; gap:1rem;">
        <span class="eyebrow">Blog post</span>
        <div style="display:grid; gap:0.75rem; max-width:52rem;">
          <h1>{title}</h1>
          <p class="page-copy">{description}</p>
        </div>
      </section>
      <section class="site-panel prose post-prose">
        <slot />
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .post-prose {
    max-width: 860px;
    width: 100%;
    margin: 0 auto;
  }

  .post-prose :global(img) {
    border: 3px solid var(--border);
    box-shadow: 6px 6px 0 rgba(31, 34, 48, 0.08);
  }
</style>
