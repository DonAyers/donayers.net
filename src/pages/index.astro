---
import '../styles/global.css';
import { withBase } from '../utils/withBase';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content="React Developer & Music Producer" />
		<title>Don Ayers</title>
	</head>
	<body class="grid-bg">
		<!-- Main Container -->
		<div class="wrapper">
			<!-- Hero Section -->
			<section class="hero">
				<h1>DON AYERS</h1>
				<!-- Navigation -->
				<nav class="nav-links">
					<a href={withBase('/')}>HOME</a>
					<span class="separator">//</span>
					<a href={withBase('/music')}>MUSIC</a>
					<span class="separator">//</span>
					<a href={withBase('/dev')}>DEV</a>
				</nav>
			</section>

			<!-- Bio Section -->
			<section class="bio">
				<p>
					Building modern web applications with React, TypeScript, and the latest tools. 
					Passionate about clean code, performance, and creating seamless user experiences.
				</p>
				<p>
					Crafting atmospheric soundscapes and electronic beats. Exploring the intersection 
					of technology and creativity through synthesis and sound design.
				</p>
			</section>
		</div>

		<style>
			.wrapper {
				position: relative;
				padding: 40px 20px;
				max-width: 900px;
				margin: 0 auto;
				min-height: 100vh;
				display: flex;
				flex-direction: column;
				justify-content: center;
				gap: 3rem;
			}

		.hero {
			text-align: center;
			margin-bottom: 2rem;
			max-height: 40vh;
			display: flex;
			flex-direction: column;
			justify-content: center;
		}

		@media (max-width: 768px) {
			.hero {
				max-height: 30vh;
			}
		}

		.line {
			height: 2px;
			background: var(--cyber-blue);
			margin: 2rem auto;
			max-width: 400px;
			box-shadow: 0 0 10px var(--cyber-blue);
		}			.nav-links {
				display: flex;
				justify-content: center;
				align-items: center;
				gap: 1rem;
				margin-top: 3rem;
				font-family: 'Orbitron', sans-serif;
				font-size: 1.2rem;
				letter-spacing: 0.2em;
			}

			.nav-links a {
				color: var(--cyber-blue);
				text-shadow: 0 0 10px var(--cyber-blue);
				font-weight: 700;
			}

			.nav-links a:hover {
				color: var(--cyber-pink);
				text-shadow: 0 0 15px var(--cyber-pink);
			}

			.separator {
				color: var(--cyber-purple);
				opacity: 0.5;
			}

			.bio {
				max-width: 700px;
				margin: 0 auto;
				line-height: 2;
			}

			.bio p {
				margin-bottom: 1.5rem;
				color: #ccc;
			}

			@media (max-width: 768px) {
				.wrapper {
					padding: 20px 15px;
				}

				.nav-links {
					flex-wrap: wrap;
					font-size: 1rem;
					gap: 0.5rem;
				}
			}
		</style>
	</body>
</html>
