---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { withBase } from '../utils/withBase';

const quickLinks = [
  { href: '/music', label: 'Explore music',   tone: 'primary' },
  { href: '/dev',   label: 'Browse dev work', tone: 'mint'    },
  { href: '/blog',  label: 'Read the blog',   tone: 'sun'     },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Don Ayers" description="Lead frontend developer and musician. Based in LA, formerly Seattle. Builds React apps by day, plays drums in bands by night." />
  </head>
  <body>
    <Header />
    <main class="site-shell page-stack">

      <!-- Hero -->
      <section class="hero-section">
        <div class="hero-content">
          <span class="eyebrow">Los Angeles · formerly Seattle</span>
          <h1 class="hero-title">Frontend dev,<br><em>musician,</em><br>and perpetual<br>tinkerer.</h1>
          <p class="lede">
            Lead frontend dev at Care Continuity by day. Guitarist, drummer, and bandmate in Seattle bands for years — Maps on Fire, Black Giraffe, Luminol. Now in LA, still building things.
          </p>
          <div class="button-row">
            {quickLinks.map((link) => (
              <a href={withBase(link.href)} class:list={['pixel-button', link.tone]}>{link.label}</a>
            ))}
          </div>
        </div>

        <!-- Geometric composition, mood-board inspired -->
        <div class="hero-geo" aria-hidden="true">
          <div class="geo geo-circle"></div>
          <div class="geo geo-rect"></div>
          <div class="geo geo-rect-sm"></div>
          <div class="geo geo-dot"></div>
          <div class="geo geo-line"></div>
        </div>
      </section>


    </main>
    <Footer />
  </body>
</html>

<style>
  /* ── Hero ─────────────────────────────────────── */
  .hero-section {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 4rem;
    align-items: center;
    padding: clamp(3rem, 6vw, 5rem) 0;
  }

  .hero-content {
    display: grid;
    gap: 1.75rem;
    align-content: start;
    min-width: 0;
  }


  .hero-title {
    font-size: clamp(3rem, 6.5vw, 5.8rem);
    font-weight: 300;
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  .hero-title em {
    font-style: italic;
    color: var(--muted);
  }

  /* ── Geometric composition ───────────────────── */
  .hero-geo {
    position: relative;
    width: 100%;
    max-width: 380px;
    aspect-ratio: 4 / 4.2;
    margin-left: auto;
  }

  .geo {
    position: absolute;
    transition: transform 8s ease-in-out;
  }

  /* Large circle — mauve, background anchor */
  .geo-circle {
    width: 68%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: var(--mauve);
    opacity: 0.38;
    right: 0;
    top: 8%;
    animation: geo-drift-1 12s ease-in-out infinite;
  }

  /* Tall rectangle — sage */
  .geo-rect {
    width: 38%;
    height: 58%;
    background: var(--sage);
    opacity: 0.38;
    left: 6%;
    bottom: 6%;
    animation: geo-drift-2 15s ease-in-out infinite;
  }

  /* Small square — terracotta */
  .geo-rect-sm {
    width: 22%;
    height: 22%;
    background: var(--terra);
    opacity: 0.55;
    right: 16%;
    bottom: 18%;
    animation: geo-drift-3 10s ease-in-out infinite;
  }

  /* Dot — indigo */
  .geo-dot {
    width: 14%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: var(--indigo);
    opacity: 0.65;
    left: 36%;
    top: 14%;
    animation: geo-drift-1 9s ease-in-out infinite reverse;
  }

  /* Hairline — structural accent */
  .geo-line {
    width: 1px;
    height: 55%;
    background: var(--border-strong);
    opacity: 0.5;
    left: 50%;
    top: 0;
    transform-origin: top center;
    animation: geo-drift-2 14s ease-in-out infinite reverse;
  }

  @keyframes geo-drift-1 {
    0%, 100% { transform: translateY(0)    rotate(0deg); }
    40%      { transform: translateY(-10px) rotate(2deg); }
    70%      { transform: translateY(-4px)  rotate(-1deg); }
  }

  @keyframes geo-drift-2 {
    0%, 100% { transform: translateY(0)   rotate(0deg); }
    35%      { transform: translateY(8px) rotate(-1.5deg); }
    65%      { transform: translateY(3px) rotate(1deg); }
  }

  @keyframes geo-drift-3 {
    0%, 100% { transform: translate(0, 0)     rotate(0deg); }
    50%      { transform: translate(-6px, -8px) rotate(6deg); }
  }

  /* ── Responsive ───────────────────────────────── */
  @media (max-width: 1200px) {
    .hero-section {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .hero-geo {
      max-width: 280px;
      margin-left: 0;
      aspect-ratio: 4 / 3;
    }
  }

  @media (max-width: 720px) {
    .hero-geo { display: none; }
  }
</style>
