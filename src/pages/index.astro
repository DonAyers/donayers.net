---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { withBase } from '../utils/withBase';

const quickLinks = [
  { href: '/music', label: 'Explore music', tone: 'primary' },
  { href: '/dev', label: 'Browse dev work', tone: 'mint' },
  { href: '/blog', label: 'Read the blog', tone: 'sun' },
];

---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Don Ayers" description="Lead frontend developer and musician. Based in LA, formerly Seattle. Builds React apps by day, plays drums in bands by night." />
  </head>
  <body class="grid-bg">
    <Header />
    <main class="site-shell page-stack">
      <section class="site-panel hero-grid">
        <div style="display:grid; gap:1.4rem; align-content:start; min-width:0;">
          <span class="eyebrow">LA · formerly Seattle</span>
          <h1>Frontend dev, drummer, and perpetual side-project starter.</h1>
          <p class="lede">
            Lead frontend dev at Care Continuity by day. Drummer in Seattle bands for years — Maps on Fire, Black Giraffe, Luminol. Now in LA, still building things.
          </p>
          <div class="button-row">
            {quickLinks.map((link) => (
              <a href={withBase(link.href)} class:list={['pixel-button', link.tone]}>{link.label}</a>
            ))}
          </div>
        </div>

        <div class="pixel-window" aria-hidden="true" style="min-height:280px;">
          <div class="shape" style="--left:10%; --top:18%; --size:72px; --fill:var(--brand); --float-dur:5.2s; --float-delay:0s;"></div>
          <div class="shape stair" style="--left:38%; --top:12%; --size:98px; --fill:var(--brand-4); --float-dur:6.5s; --float-delay:-1.6s;"></div>
          <div class="shape dot" style="--left:72%; --top:18%; --size:64px; --fill:var(--brand-3); --float-dur:4.2s; --float-delay:-3.1s;"></div>
          <div class="shape tall" style="--left:24%; --top:46%; --size:52px; --fill:var(--brand-2); --float-dur:5.8s; --float-delay:-0.9s;"></div>
          <div class="shape dot" style="--left:62%; --top:50%; --size:48px; --fill:var(--brand-4); --float-dur:7.1s; --float-delay:-2.4s;"></div>
          <div class="shape" style="--left:78%; --top:44%; --size:36px; --fill:var(--brand); --float-dur:4.8s; --float-delay:-4.0s;"></div>
          <div class="ground"></div>
        </div>
      </section>

      <section class="card-grid two-up">
        <article class="project-card" data-accent="purple">
          <span class="eyebrow dev">Dev</span>
          <h2>Lead frontend dev at Care Continuity, plus side projects.</h2>
          <p class="page-copy">
            React, TypeScript, and a focus on interfaces that hold up under real-world pressure. Also: a music transcription app, a pixel art generator, and an AI platformer.
          </p>
          <a href={withBase('/dev')} class="inline-link">See dev projects →</a>
        </article>

        <article class="project-card" data-accent="teal">
          <span class="eyebrow music">Music</span>
          <h2>Drummer in Seattle bands for a decade.</h2>
          <p class="page-copy">
            Maps on Fire, Black Giraffe, Luminol, Read Underwater. Rock, soul, ambient, and everything in between. All on Bandcamp.
          </p>
          <a href={withBase('/music')} class="inline-link">See music projects →</a>
        </article>
      </section>
    </main>
    <Footer />
  </body>
</html>
