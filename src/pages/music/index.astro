---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { withBase } from '../../utils/withBase';

const musicProjects = (await getCollection('music')).sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return (b.data.releaseDate?.valueOf() ?? 0) - (a.data.releaseDate?.valueOf() ?? 0);
});

const bandcampEmbedIds: Record<string, string> = {
  'black-giraffe':   '2657265468',
  'maps-on-fire':    '1997636830',
  'luminol':         '2349734073',
  'read-underwater': '3093460534',
};

const bandColors: Record<string, { key: string; bg: string; accent: string }> = {
  'black-giraffe':   { key: 'coral',  bg: 'rgba(255,96,64,0.14)',   accent: '#ff6040' },
  'maps-on-fire':    { key: 'purple', bg: 'rgba(91,71,245,0.14)',   accent: '#5b47f5' },
  'luminol':         { key: 'teal',   bg: 'rgba(11,184,164,0.14)',  accent: '#0bb8a4' },
  'read-underwater': { key: 'sun',    bg: 'rgba(255,200,50,0.18)',  accent: '#ffc832' },
};
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Music | Don Ayers" description="Bands, projects, and a decade of Seattle drums." />
  </head>
  <body class="grid-bg">
    <Header />
    <main class="site-shell page-stack">

      <section class="music-header site-panel">
        <div class="music-header-text">
          <span class="eyebrow music">Music</span>
          <h1>Bands, projects, and a decade of Seattle drums.</h1>
          <p class="page-copy">Rock, soul, ambient, and experimental. Play tracks below or open any project for the full details.</p>
        </div>
        <div class="music-header-shapes" aria-hidden="true">
          <div class="mhs mhs-1"></div>
          <div class="mhs mhs-2"></div>
          <div class="mhs mhs-3"></div>
          <div class="mhs mhs-4"></div>
        </div>
      </section>

      <section class="music-grid">
        {musicProjects.map((project) => {
          const embedId = bandcampEmbedIds[project.id];
          const color = bandColors[project.id];
          const year = project.data.releaseDate ? new Date(project.data.releaseDate).getFullYear() : null;
          return (
            <article class="music-card" style={`--card-bg: ${color?.bg ?? 'rgba(91,71,245,0.1)'}; --card-accent: ${color?.accent ?? '#5b47f5'};`}>
              <div class="music-card-header">
                <div class="music-card-title-block">
                  <h2 class="music-card-title">{project.data.title}</h2>
                  {project.data.genre && (
                    <p class="music-card-genre">{project.data.genre.join(' · ')}</p>
                  )}
                </div>
                {year && <span class="music-card-year">{year}</span>}
              </div>

              {project.data.description && (
                <p class="music-card-desc">{project.data.description}</p>
              )}

              {embedId && (
                <div class="music-card-player">
                  <iframe
                    src={`https://bandcamp.com/EmbeddedPlayer/album=${embedId}/size=small/bgcol=fffdf8/linkcol=5b47f5/transparent=true/`}
                    seamless
                    title={`${project.data.title} on Bandcamp`}
                    class="bandcamp-mini"
                  ></iframe>
                </div>
              )}

              <div class="music-card-footer">
                <a href={withBase(`/music/${project.id}`)} class="music-card-link">
                  Full details →
                </a>
                {project.data.links?.filter(l => l?.url).map(link => (
                  <a href={link!.url!} target="_blank" rel="noopener noreferrer" class="music-card-link secondary">
                    {link!.platform} ↗
                  </a>
                ))}
              </div>
            </article>
          );
        })}
      </section>

    </main>
    <Footer />
  </body>
</html>

<style>
  /* ── Header ─────────────────────────────────────── */
  .music-header {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    min-height: 200px;
    padding: clamp(1.5rem, 3vw, 2.5rem);
  }

  .music-header-text {
    position: relative;
    z-index: 2;
    display: grid;
    gap: 0.9rem;
    max-width: 560px;
  }

  .music-header-shapes {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  .mhs {
    position: absolute;
    border: 3px solid var(--border);
    animation: shape-float 5s ease-in-out infinite;
  }
  .mhs-1 { width: 88px;  height: 88px;  right: 8%;  top: 10%;  background: var(--brand);   opacity: 0.18; animation-duration: 5.5s; }
  .mhs-2 { width: 60px;  height: 60px;  right: 22%; top: 55%;  background: var(--brand-3); opacity: 0.18; border-radius: 999px; animation-duration: 7s; animation-delay: -2s; }
  .mhs-3 { width: 48px;  height: 72px;  right: 14%; top: 38%;  background: var(--brand-2); opacity: 0.18; animation-duration: 6s; animation-delay: -3.5s; }
  .mhs-4 { width: 72px;  height: 72px;  right: 32%; top: 15%;  background: var(--brand-4); opacity: 0.18;
    clip-path: polygon(0 0,100% 0,100% 33%,66% 33%,66% 66%,33% 66%,33% 100%,0 100%);
    animation-duration: 8s; animation-delay: -1s;
  }

  /* ── Grid ────────────────────────────────────────── */
  .music-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 860px) {
    .music-grid { grid-template-columns: 1fr; }
  }

  /* ── Card ────────────────────────────────────────── */
  .music-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border: 3px solid var(--border);
    background: var(--panel-strong);
    box-shadow: var(--shadow), var(--shadow-soft);
    overflow: hidden;
    transition: transform 120ms ease, box-shadow 120ms ease;
    position: relative;
  }

  .music-card::before {
    content: '';
    display: block;
    height: 6px;
    background: var(--card-accent);
  }

  .music-card:hover {
    transform: translate(-2px, -2px);
    box-shadow: 8px 8px 0 rgba(26,29,46,0.14), var(--shadow-soft);
  }

  .music-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 1.25rem 0;
    background: var(--card-bg);
    padding-bottom: 1.25rem;
    border-bottom: 2px dashed rgba(26,29,46,0.1);
  }

  .music-card-title-block {
    display: grid;
    gap: 0.35rem;
  }

  .music-card-title {
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    margin: 0;
  }

  .music-card-genre {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    margin: 0;
  }

  .music-card-year {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.55rem;
    border: 2px solid var(--border);
    background: rgba(255,253,248,0.9);
    font-family: 'Silkscreen', sans-serif;
    font-size: 0.62rem;
    box-shadow: 3px 3px 0 rgba(26,29,46,0.08);
    white-space: nowrap;
  }

  .music-card-desc {
    padding: 0 1.25rem;
    font-size: 0.88rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.6;
  }

  .music-card-player {
    padding: 0 1.25rem;
  }

  .bandcamp-mini {
    border: 0;
    width: 100%;
    height: 42px;
    display: block;
  }

  .music-card-footer {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
    padding: 0.75rem 1.25rem 1.25rem;
    border-top: 1px solid rgba(26,29,46,0.08);
    margin-top: auto;
  }

  .music-card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: 'Silkscreen', sans-serif;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    color: var(--card-accent);
    font-weight: 600;
    transition: gap 120ms ease, opacity 120ms ease;
  }

  .music-card-link:hover { gap: 0.55rem; opacity: 0.8; }
  .music-card-link.secondary { color: var(--muted); }
  .music-card-link.secondary:hover { color: var(--brand-3); }
</style>
