---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { withBase } from '../../utils/withBase';

const musicProjects = (await getCollection('music')).sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return (b.data.releaseDate?.valueOf() ?? 0) - (a.data.releaseDate?.valueOf() ?? 0);
});

const bandcampEmbedIds: Record<string, string> = {
  'black-giraffe':   '2657265468',
  'maps-on-fire':    '1997636830',
  'luminol':         '2349734073',
  'read-underwater': '3093460534',
};

const bandColors: Record<string, { accent: string; embedColor: string }> = {
  'black-giraffe':   { accent: '#9b5f4e', embedColor: '9b5f4e' },
  'maps-on-fire':    { accent: '#8c80bc', embedColor: '8c80bc' },
  'luminol':         { accent: '#7aa87e', embedColor: '7aa87e' },
  'read-underwater': { accent: '#b8a4bc', embedColor: 'b8a4bc' },
};
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Music | Don Ayers" description="Bands, projects, and a decade of Seattle drums." />
  </head>
  <body>
    <Header />
    <main class="site-shell page-stack">

      <section class="music-hero site-panel">
        <span class="eyebrow music">Music</span>
        <h1>Bands, projects, and<br><em>a decade of Seattle drums.</em></h1>
        <p class="lede">Rock, soul, ambient, and experimental. Play tracks below or open any project for the full details.</p>
      </section>

      <section class="music-grid">
        {musicProjects.map((project) => {
          const embedId = bandcampEmbedIds[project.id];
          const color = bandColors[project.id];
          const year = project.data.releaseDate ? new Date(project.data.releaseDate).getFullYear() : null;
          return (
            <article class="music-card" style={`--card-accent: ${color?.accent ?? '#8c80bc'};`}>
              <div class="music-card-inner">
                <div class="music-card-header">
                  <div class="music-card-title-block">
                    <h2 class="music-card-title">{project.data.title}</h2>
                    {project.data.genre && (
                      <p class="music-card-genre">{project.data.genre.join(' · ')}</p>
                    )}
                  </div>
                  {year && <span class="music-card-year">{year}</span>}
                </div>

                {project.data.description && (
                  <p class="music-card-desc">{project.data.description}</p>
                )}

                {embedId && (
                  <div class="music-card-player">
                    <iframe
                      src={`https://bandcamp.com/EmbeddedPlayer/album=${embedId}/size=small/bgcol=faf6f0/linkcol=${color?.embedColor ?? '8c80bc'}/transparent=true/`}
                      seamless
                      title={`${project.data.title} on Bandcamp`}
                      class="bandcamp-mini"
                    ></iframe>
                  </div>
                )}

                <div class="music-card-footer">
                  <a href={withBase(`/music/${project.id}`)} class="music-card-link">
                    Full details →
                  </a>
                  {project.data.links?.filter(l => l?.url).map(link => (
                    <a href={link!.url!} target="_blank" rel="noopener noreferrer" class="music-card-link secondary">
                      {link!.platform} ↗
                    </a>
                  ))}
                </div>
              </div>
            </article>
          );
        })}
      </section>

    </main>
    <Footer />
  </body>
</html>

<style>
  /* ── Hero ─────────────────────────────────────── */
  .music-hero {
    display: grid;
    gap: 1.25rem;
    padding: clamp(2.5rem, 5vw, 4rem) 0;
  }

  .music-hero h1 {
    font-size: clamp(2.5rem, 5.5vw, 5rem);
  }

  .music-hero h1 em {
    font-style: italic;
    color: var(--muted);
  }

  /* ── Grid ─────────────────────────────────────── */
  .music-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
  }

  @media (max-width: 860px) {
    .music-grid { grid-template-columns: 1fr; }
  }

  /* ── Card ─────────────────────────────────────── */
  .music-card {
    border-bottom: 1px solid var(--border);
    position: relative;
  }

  /* Odd cards get a right border to form the grid */
  .music-grid .music-card:nth-child(odd) {
    border-right: 1px solid var(--border);
  }

  /* Accent strip along the left edge */
  .music-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--card-accent);
    opacity: 0.8;
  }

  .music-card-inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: clamp(1.5rem, 3vw, 2rem) clamp(1.5rem, 3vw, 2rem) clamp(1.5rem, 3vw, 2rem) calc(clamp(1.5rem, 3vw, 2rem) + 0.75rem);
    height: 100%;
  }

  /* ── Card header ──────────────────────────────── */
  .music-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .music-card-title-block {
    display: grid;
    gap: 0.35rem;
  }

  .music-card-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 300;
    margin: 0;
    letter-spacing: -0.01em;
    line-height: 1.1;
  }

  .music-card-genre {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.58rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
    margin: 0;
  }

  .music-card-year {
    flex-shrink: 0;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: var(--muted);
    padding-top: 0.15rem;
  }

  /* ── Description ──────────────────────────────── */
  .music-card-desc {
    font-size: 0.9rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.7;
    font-weight: 300;
  }

  /* ── Player ───────────────────────────────────── */
  .music-card-player {
    /* no extra padding needed */
  }

  .bandcamp-mini {
    border: 0;
    width: 100%;
    height: 42px;
    display: block;
    opacity: 0.9;
  }

  /* ── Footer ───────────────────────────────────── */
  .music-card-footer {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    align-items: center;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
  }

  .music-card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-decoration: none;
    color: var(--muted);
    transition: color 150ms ease, gap 150ms ease;
  }

  .music-card-link:hover { color: var(--text); gap: 0.5rem; }
  .music-card-link.secondary { opacity: 0.75; }
  .music-card-link.secondary:hover { opacity: 1; }

  /* ── Responsive ───────────────────────────────── */
  @media (max-width: 860px) {
    .music-grid .music-card:nth-child(odd) {
      border-right: none;
    }
  }
</style>
