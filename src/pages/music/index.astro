---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { withBase } from '../../utils/withBase';

const musicProjects = await getCollection('music');
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Music | Don Ayers" description="Music releases and experiments from Don Ayers." />
  </head>
  <body class="grid-bg">
    <Header />
    <main class="site-shell page-stack">
      <section class="site-panel" style="display:grid; gap:1rem;">
        <span class="eyebrow music">Music</span>
        <div class="section-heading">
          <div style="display:grid; gap:0.75rem;">
            <h1>Electronic work with a little neon left in it.</h1>
            <p class="page-copy">Tracks, release notes, and sketches that pair well with late-night browser tabs.</p>
          </div>
          <span class="stat-pill"><strong>{musicProjects.length}</strong> projects</span>
        </div>
      </section>

      <section class="card-grid">
        {musicProjects.map((project) => (
          <article class="project-card" data-accent="teal">
            <div class="section-heading">
              <div style="display:grid; gap:0.55rem;">
                <h2>{project.data.title}</h2>
                {project.data.genre && <p class="card-meta">{project.data.genre.join(' / ')}</p>}
              </div>
              {project.data.releaseDate && (
                <span class="tag-pill"><strong>Released</strong> {new Date(project.data.releaseDate).getFullYear()}</span>
              )}
            </div>
            {project.data.description && <p class="page-copy">{project.data.description}</p>}
            <div class="card-links">
              <a href={withBase(`/music/${project.id}`)} class="inline-link">Open details →</a>
              {project.data.links?.filter((link) => link?.url).map((link) => (
                <a href={link.url ?? '#'} class="inline-link" target="_blank" rel="noopener noreferrer">
                  {link.platform || 'Listen'} ↗
                </a>
              ))}
            </div>
          </article>
        ))}
      </section>
    </main>
    <Footer />
  </body>
</html>
