---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { withBase } from '../../utils/withBase';

const devProjects = await getCollection('dev');
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Dev | Don Ayers" description="Development work and case studies from Don Ayers." />
  </head>
  <body class="grid-bg">
    <Header />
    <main class="site-shell page-stack">
      <section class="site-panel" style="display:grid; gap:1rem;">
        <span class="eyebrow dev">Dev</span>
        <div class="section-heading">
          <div style="display:grid; gap:0.75rem;">
            <h1>Modern frontend builds with tight interaction details.</h1>
            <p class="page-copy">A simple list of projects, stacks, and links out to demos or source where available.</p>
          </div>
          <span class="stat-pill"><strong>{devProjects.length}</strong> projects</span>
        </div>
      </section>

      <section class="card-grid">
        {devProjects.map((project) => (
          <article class="project-card" data-accent="purple">
            <div class="section-heading">
              <div style="display:grid; gap:0.55rem;">
                <h2>{project.data.title}</h2>
                {project.data.tech && <p class="card-meta">{project.data.tech.join(' / ')}</p>}
              </div>
              {project.data.status && <span class="tag-pill"><strong>Status</strong> {project.data.status}</span>}
            </div>
            {project.data.description && <p class="page-copy">{project.data.description}</p>}
            <div class="card-links">
              <a href={withBase(`/dev/${project.id}`)} class="inline-link">Read details →</a>
              {project.data.githubUrl && (
                <a href={project.data.githubUrl} class="inline-link" target="_blank" rel="noopener noreferrer">GitHub ↗</a>
              )}
              {project.data.liveUrl && (
                <a href={project.data.liveUrl} class="inline-link" target="_blank" rel="noopener noreferrer">Live demo ↗</a>
              )}
            </div>
          </article>
        ))}
      </section>
    </main>
    <Footer />
  </body>
</html>
